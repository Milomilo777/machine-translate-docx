# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
venv/
env/
.env
.env.*

# IDE
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db

# Logs / temp
*.log
*.tmp

# Local runtime data (created by local_launcher.py)
/tmp/machine_translate_docx_local/

# Claude Code local config (exclude personal settings, keep shared rules)
.claude/
!.claude/rules/
!.claude/rules/**
# `.claude/launch.json` is worktree-personal (Claude Preview port mapping);
# do NOT track. `.claude/settings.local*.json` ditto. The two patterns
# below are redundant with the `.claude/` blanket above but are explicit
# defenses in case someone narrows the blanket later.
.claude/launch.json
.claude/settings.local*.json

# Newsletter subscribers — never committed
subscribers.txt

# v2 frontend Tailwind toolchain — compiled tailwind.css IS committed,
# but the dependency tree is not. Rebuild via `npm install` in web/v2/.
web/v2/node_modules/

# Local working notes (untracked, user-only — promote to docs/ when ready)
.doc/

# Translation outputs left in the working tree by previous test runs.
# tests/fixtures/ is the canonical fixture location; everything else is
# scratch and should not land in the repo.
/*_PER_*.docx
/*_PER_*.json
/*_GER_*.docx
/*_ARA_*.docx
/*_MON_*.docx

# Smoke / live target output directory (created by `tasks.bat smoke`
# and the `make smoke` / `make live-*` targets). Always scratch.
/_real_test/
