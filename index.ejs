<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
	<meta name="robots" content="noindex, nofollow">

    <title>Document Translator</title>
    <link
      href="/static/tailwind.min.css"
      rel="stylesheet"
    />
    <style>
      .loader {
        border-top-color: #3498db;
        -webkit-animation: spinner 1.5s linear infinite;
        animation: spinner 1.5s linear infinite;
      }

      @-webkit-keyframes spinner {
        0% { -webkit-transform: rotate(0deg); }
        100% { -webkit-transform: rotate(360deg); }
      }

      @keyframes spinner {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
      }

      /* Ensure custom alert fades in/out smoothly */
      #customAlert { opacity: 0; transition: opacity 0.25s ease; }
      #customAlert.show { opacity: 1; }

      /* Safari/backdrop fallbacks */
      .backdrop-safe {
        -webkit-backdrop-filter: blur(6px);
        backdrop-filter: blur(6px);
      }

      /* Prevent layout collapse on flex/grid children in some Safari builds */
      .avoid-collapse { min-height: 1px; }

      /* Ensure loading overlay covers and is hidden by default */
      #loading { display: none; }
      #loading.visible { display: flex; }

    </style>
  </head>
  <body class="bg-gray-100 p-4">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Left column: Form -->
      <div class="md:col-span-2 bg-white p-8 rounded shadow-md avoid-collapse">
        <h1 class="text-2xl font-bold mb-4">Document Translator</h1>
        <form id="translationForm" action="/upload" method="post" enctype="multipart/form-data">
          <label for="docxFile" class="block mb-2 text-sm text-gray-600">Select DOCX File:</label>
          <input type="file" id="docxFile" accept=".docx" name="file" class="w-full mb-4 p-2 border rounded" onchange="validateFile()" />

          <label for="xlsxFile" class="block mb-2 text-sm text-gray-600">Select XLSX File (Optional):<br/><i>Custom search-and-replace table. If empty, the default file in <code>src/configuration/</code> is used.</i></label>
          <input type="file" id="xlsxFile" name="xlsxFile" accept=".xlsx" class="w-full mb-4 p-2 border rounded" />

          <label for="sourceLanguages" class="block mb-2 text-sm text-gray-600">Source Language:</label>
          <select id="sourceLanguages" class="w-full mb-4 p-2 border rounded" name="sourceLanguage"></select>

          <label for="targetLanguages" class="block mb-2 text-sm text-gray-600">Target Languages:</label>
          <select id="targetLanguages" class="w-full mb-4 p-2 border rounded" name="targetLanguage"></select>

          <label for="translationEngine" class="block mb-2 text-sm text-gray-600">Translation Engine: </label>
          <select id="translationEngine" class="w-full mb-4 p-2 border rounded" name="engine">
            <option id="google-engine-option" value="google">Google Translate</option>
            <option id="deepl-engine-option" value="deepl">Deepl</option>
            <option id="openai-engine-option" value="chatgpt">OpenAI API</option>
            <option id="openai-polish-engine-option" value="chatgpt-polish">OpenAI Translation + Polish</option>
          </select>

          <div id="aiModelRow" style="display:none;">
            <label for="aiModel" class="block mb-2 text-sm text-gray-600">OpenAI Model:</label>
            <select id="aiModel" class="w-full mb-4 p-2 border rounded" name="aiModel">
              <!-- F-1 (2026-05-11): values match config.VALID_AI_MODELS.
                   The stale gpt-5.4 option was removed because the CLI
                   rejects it at parse time (B-004). -->
              <option value="gpt-5.5" selected>GPT-5.5 — Recommended</option>
              <option value="gpt-5.4-mini">GPT-5.4-mini — Faster, cheaper</option>
            </select>
          </div>

          <div id="splitSection">
            <div class="flex py-2 mb-2">
              <input type="checkbox" id="splitTranslate" class="mr-2" name="splitTranslate" checked />
              <label for="splitTranslate" class="block text-sm text-gray-600">Splittranslation:</label>
            </div>
            <label for="splitEngine" class="block mb-2 text-sm text-gray-600">Split Method: </label>
            <select id="splitEngine" class="w-full mb-4 p-2 border rounded" name="splitEngine" disabled>
              <option id="basic-split-option" value="basic">Basic with excel file</option>
              <option id="openai-split-option" value="openai">OpenAI API</option>
              <option id="persian-double-lines-split-option" value="persian_double_lines">Persian Double Lines</option>
            </select>
            <div id="alignerMaxCharsRow" class="mb-3 hidden">
              <label for="alignerMaxChars" class="block mb-1 text-sm text-gray-600">
                Persian Double Lines — Max chars per chunk (CPL ceiling):
                <span id="alignerMaxCharsValue" class="font-mono text-gray-800">45</span>
              </label>
              <input type="range" id="alignerMaxChars" name="alignerMaxChars"
                     min="24" max="70" step="1" value="45" class="w-full" />
              <div class="flex justify-between text-xs text-gray-500">
                <span>24 — tight (very short chunks)</span>
                <span>45 — default (balanced)</span>
                <span>70 — loose (broader chunks)</span>
              </div>
              <p class="text-xs text-gray-500 mt-1">
                Maximum character width of each Persian chunk in the
                bilingual double-line output. Default 45 matches the
                historical broadcast ceiling. The setting is remembered
                in your browser between runs.
              </p>
            </div>
            <div id="alignerThresholdRow" class="mb-3 hidden">
              <label for="alignerLlmThreshold" class="block mb-1 text-sm text-gray-600">
                Persian Double Lines — Aligner LLM Threshold:
                <span id="alignerLlmThresholdValue" class="font-mono text-gray-800">0</span>
              </label>
              <input type="range" id="alignerLlmThreshold" name="alignerLlmThreshold"
                     min="0" max="100" step="1" value="0" class="w-full" />
              <div class="flex justify-between text-xs text-gray-500">
                <span>0 — mechanical only (fast, no cost)</span>
                <span>40 — balanced (recommended)</span>
                <span>100 — model-driven (slow)</span>
              </div>
              <p class="text-xs text-gray-500 mt-1">
                The mechanical aligner handles every group by default. As you
                raise the threshold the LLM (gpt-5.4-mini) rescues the hardest
                groups — those with rows close to the 48-char broadcast limit
                or with forced merges. Calibrated sweet spot on real
                Persian-translated docx is around <strong>40</strong>:
                ~2&nbsp;% of groups go to the model, long-line count drops
                ~15&nbsp;%, doubles stay in the 50&nbsp;% band, and a typical
                document takes ~2–5 extra minutes for a few cents of OpenAI
                tokens. Use 0 if you need the cheapest, most predictable run.
              </p>
            </div>
          </div>
		  
          <div class="flex py-2 mb-2 items-center space-x-2">
            <input type="checkbox" id="enableSound" class="mr-2" name="enableSound" checked>
            <label for="enableSound" class="block text-sm text-gray-600 mr-2">Play sound notification after translation:</label>

            <select id="soundSelect" class="p-2 border rounded" name="soundSelect">
              <option value="https://cdn.pixabay.com/download/audio/2025/05/06/audio_2fd68b9a9a.mp3?filename=bell-notification-337658.mp3" selected>Bell Notification</option>
              <option value="https://cdn.pixabay.com/download/audio/2024/11/29/audio_538916a9ed.mp3?filename=notification-18-270129.mp3">Notification 1</option>
              <option value="https://cdn.pixabay.com/download/audio/2023/07/14/audio_3020bd99cc.mp3?filename=notification-9-158194.mp3">Notification 9</option>
            </select>

            <button type="button" id="testSoundBtn" class="bg-gray-200 px-3 py-1 rounded text-sm text-gray-700 border">▶️ Test</button>
          </div>

          <button type="button" id="translateBtn" class="w-full bg-blue-500 text-white p-2 rounded">Translate Document</button>

          <div class="py-2 mb-2 flex">
            <h3 class="font-bold">Translated Document so far:&nbsp;</h3>
            <p id="counter"></p>
          </div>
          <div class="py-2 mb-2 flex">
            <h3 class="font-bold">Currently processing : &nbsp;</h3>
            <p id="nb_processing"></p>
          </div>
        </form>

        <div id="loading" class="fixed top-0 left-0 right-0 bottom-0 w-full h-screen z-50 overflow-hidden bg-gray-700 opacity-75 flex flex-col items-center justify-center">
          <div class="loader ease-linear rounded-full border-4 border-t-4 border-gray-200 h-12 w-12 mb-4"></div>
          <h2 class="text-center text-white text-xl font-semibold">Loading...</h2>
          <p class="w-1/3 text-center text-white">This may take a few minutes, please don't close this page.</p>
          <div class="mt-6 w-1/2 max-w-md">
            <div class="flex items-center justify-between text-white text-sm mb-1">
              <span id="progressLabel">Starting…</span>
              <span id="progressPct">0%</span>
            </div>
            <progress id="progressBar" value="0" max="100" class="w-full h-3"></progress>
            <div class="mt-4 flex justify-center">
              <button type="button" id="cancelBtn"
                class="bg-red-600 hover:bg-red-700 text-white text-sm px-4 py-2 rounded shadow">
                Cancel translation
              </button>
            </div>
          </div>
        </div>

        <div id="result" class="mt-8"></div>
        <p>In case of bugs or error, please report to smtv.bot at gmail dot com for support.</p>
      </div>

      <!-- Right column: About & Latest Updates -->
      <div class="mt-8 avoid-collapse">
        <h2 class="text-xl font-bold mb-4">About the Machine Translation Robot</h2>
        <div class="space-y-4">
          <div class="p-4 bg-gray-50 rounded-lg shadow">
            <h3 class="font-semibold text-lg mb-2">The source code is available for free on github</h3>
            <p class="text-gray-700">The source code is available on the translation-robot account on GitHub: <b><a href="https://github.com/translation-robot/machine-translate-docx/">https://github.com/translation-robot/machine-translate-docx/</a></b></p>
          </div>

          <div class="p-4 bg-gray-50 rounded-lg shadow">
            <h3 class="font-semibold text-lg mb-2">Download the Machine Translator and run it on your computer</h3>
            <p class="text-gray-700">Mac OS X and Windows installers are available for <b><a href="https://github.com/translation-robot/machine-translate-docx/blob/main/download.md">download</a></b>. This web site and the robot runs on Linux, but no linux installers are provided for now.</p>
          </div>

          <h2 class="text-xl font-bold mb-4">Latest Updates</h2>
		  
          <div id="update1" class="p-4 bg-gray-50 rounded-lg shadow">
            <h3 class="font-semibold text-lg mb-2"><font color="#0000FF">March 29th, 2026: Line splitting with OpenAI API is now available for testing for Persian language only.</font></h3>
            <p class="text-gray-700"><u>It must be selected in the combo box instead of basic line splitting. It makes processing 5 times slower, but quality of subtitle phrase splitting is improved significantly. Other languages will be added later after it is optimized.</u></p>
          </div>
		  
          <div id="update1" class="p-4 bg-gray-50 rounded-lg shadow">
            <h3 class="font-semibold text-lg mb-2">May 2026: OpenAI model selector added — default is GPT-5.5</h3>
            <p class="text-gray-700"><u>When using <b>OpenAI API</b> or <b>OpenAI Translation + Polish</b>, you can now select the model. Default is GPT-5.5.</u></p>
          </div>
		  
          <div id="update1" class="p-4 bg-gray-50 rounded-lg shadow">
            <h3 class="font-semibold text-lg mb-2">January 13, 2026: OpenAI (ChatGPT) using model 5.2 is now available for all languages.</h3>
            <p class="text-gray-700"><u>Please select <b>OpenAI API</b> when using GPT-5.2 as translation engine.</u></p>
          </div>
		  
		  <div id="update1" class="p-4 bg-gray-50 rounded-lg shadow">
            <h3 class="font-semibold text-lg mb-2">January 13, 2026:  Deepl added support for 70+ languages.</h3>
            <p class="text-gray-700"><u>All listed langues on this web site are now supported by Deepl except Thai, and now uses Deepl by default. We would like to receive your feedback and if you prefer having Google translate for your language.</u></p>
          </div>

          <div id="update1" class="p-4 bg-gray-50 rounded-lg shadow">
            <h3 class="font-semibold text-lg mb-2">October 23, 2025: Fixed Deepl translation.</h3>
            <p class="text-gray-700"><u>Deepl translation only work after updating to the version 2025-10-23. Use the download link on this page to get the latest version.</u></p>
          </div>

          <div id="update1" class="p-4 bg-gray-50 rounded-lg shadow">
            <h3 class="font-semibold text-lg mb-2">October 16, 2025: Fixed some slow Deepl translation cases.</h3>
            <p class="text-gray-700">Deepl slow translation should mostly be fixed. The robot does not use phrase by phrase translation from the beginning in case of failure.</p>
          </div>

          <div id="update3" class="p-4 bg-gray-50 rounded-lg shadow">
            <h3 class="font-semibold text-lg mb-2">Line splitting improvements</h3>
            <p class="text-gray-700">Short line splitting are now improved, fixing some empty lines in translation.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Custom alert modal -->
    <div id="customAlert" class="hidden fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50">
      <div class="bg-white rounded-lg shadow-lg p-6 max-w-sm text-center">
        <p id="customAlertMessage" class="text-gray-800 mb-4"></p>
        <button id="customAlertBtn" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">OK</button>
      </div>
    </div>

    <!-- ===== Safari-safe scripts (single-file) ===== -->
    <script>
    // Wrap all initialization inside DOMContentLoaded to ensure elements exist
    document.addEventListener('DOMContentLoaded', function () {
      // ------- Elements -------
      const enableSoundCheckbox = document.getElementById('enableSound');
      const soundSelect = document.getElementById('soundSelect');
      const testSoundBtn = document.getElementById('testSoundBtn');
      const translateBtn = document.getElementById('translateBtn');
      const loadingElement = document.getElementById('loading');

      // ------- Utilities -------
      function showAlert(message) {
        const modal = document.getElementById('customAlert');
        const msg = document.getElementById('customAlertMessage');
        const btn = document.getElementById('customAlertBtn');
        msg.textContent = message;
        modal.classList.remove('hidden');
        // small timeout to allow transition
        setTimeout(() => modal.classList.add('show'), 10);
        return new Promise(resolve => {
          btn.onclick = () => {
            modal.classList.remove('show');
            setTimeout(() => {
              modal.classList.add('hidden');
              resolve();
            }, 250);
          };
        });
      }

      // Render a compact run-summary card into #result after a job
       // finishes. Pulls fields from the JSON sidecar (run_info, summary,
       // blocks). Best-effort: every field is optional and rendered as
       // "—" when missing.
       function renderRunSummary(log, displayName) {
         const result = document.getElementById('result');
         if (!result) return;
         const ri = log.run_info || {};
         const sm = log.summary  || {};
         const blocks = Array.isArray(log.blocks) ? log.blocks : [];

         // Pull headline numbers
         const model       = ri.model || sm.model || (blocks[0] && blocks[0].translation && blocks[0].translation.model) || '—';
         const srcLang     = ri.source_lang || '—';
         const dstLang     = ri.dest_lang   || '—';
         const elapsed     = (sm.elapsed_total_seconds != null ? sm.elapsed_total_seconds : null);
         const rows        = sm.row_count != null ? sm.row_count : (sm.target_rows_nonempty != null ? sm.target_rows_nonempty : null);
         const tokens      = sm.total_tokens != null ? sm.total_tokens : null;
         const cached      = sm.total_cached_tokens != null ? sm.total_cached_tokens : null;
         const cost        = (typeof sm.total_cost_usd === 'number') ? sm.total_cost_usd : null;
         // Polish stats from the first block if present
         const polish = (blocks[0] && blocks[0].polish) || null;
         const linesProcessed = polish && polish.lines_processed != null ? polish.lines_processed : null;
         const linesModified  = polish && polish.lines_modified  != null ? polish.lines_modified  : null;
         const polishSkipped  = polish && polish.polish_skipped === true;
         const wasReconciled  = polish && polish.was_reconciled === true;

         function row(label, value) {
           if (value === null || value === undefined || value === '') return '';
           return '<div class="flex justify-between text-sm py-0.5"><span class="text-gray-500">'
                  + label + '</span><span class="font-mono text-gray-800">' + value + '</span></div>';
         }
         function fmtNum(n) {
           if (n == null) return '—';
           return Number(n).toLocaleString();
         }
         function fmtSec(s) {
           if (s == null) return '—';
           if (s < 60) return s.toFixed(1) + ' s';
           const m = Math.floor(s / 60);
           const rem = Math.round(s - m * 60);
           return m + ' min ' + rem + ' s';
         }

         let polishLine = '';
         if (polish) {
           if (polishSkipped) {
             polishLine = row('Polish', '<span class="text-yellow-700">skipped (' + (polish.skipped_reason || 'unknown') + ')</span>');
           } else if (linesModified != null && linesProcessed != null) {
             const pct = linesProcessed > 0 ? Math.round(100 * linesModified / linesProcessed) : 0;
             let note = '';
             if (wasReconciled) note = ' <span class="text-gray-500 text-xs">(line-shape repaired by reconciler — count is a lower bound)</span>';
             polishLine = row('Polish lines modified', linesModified + ' / ' + linesProcessed + ' (' + pct + ' %)' + note);
           }
         }

         result.innerHTML =
           '<div class="bg-white p-4 mt-4 rounded shadow-sm border border-gray-200">'
           + '<h3 class="font-bold text-base mb-2">Run summary — ' + displayName + '</h3>'
           + row('Model',              model)
           + row('Source → Target',    srcLang + ' → ' + dstLang)
           + row('Rows',               fmtNum(rows))
           + row('Elapsed',            fmtSec(elapsed))
           + row('Input tokens',       fmtNum(tokens))
           + row('Cached input tokens', fmtNum(cached))
           + row('Estimated cost USD', cost != null ? '$ ' + cost.toFixed(4) : '—')
           + polishLine
           + '</div>';
       }

      function flashTabTitle(message) {
        const originalTitle = document.title;
        let flash = true;
        const interval = setInterval(() => {
          document.title = flash ? `⚠️ ${message}` : originalTitle;
          flash = !flash;
        }, 800);
        setTimeout(() => { clearInterval(interval); document.title = originalTitle; }, 5000);
      }

      function safeOpenURL(url) {
        try {
          const win = window.open(url, '_blank');
          if (!win) window.location.href = url;
        } catch (e) { window.location.href = url; }
      }

      // ------- Sound controls -------
      function updateSoundControls() {
        const enabled = !!enableSoundCheckbox.checked;
        soundSelect.disabled = !enabled;
        testSoundBtn.disabled = !enabled;
      }

      enableSoundCheckbox.addEventListener('change', updateSoundControls);
      testSoundBtn.addEventListener('click', () => {
        const src = soundSelect.value;
        if (!src) return;
        try {
          const audio = new Audio(src);
          audio.volume = 0.5;
          audio.play().catch(err => console.warn('Autoplay prevented:', err));
        } catch (err) { console.warn('Could not play test sound:', err); }
      });

      updateSoundControls();

      // ------- Fetch counters (Safari-safe) -------
      (async function loadCounters() {
        try {
          const sf = await fetch('/count');
          if (sf.ok) {
            try {
              const data = await sf.json();
              const el = document.querySelector('#counter');
              if (el) el.textContent = data.count;
            } catch (e) { console.warn('/count: invalid json', e); }
          } else { console.warn('/count returned', sf.status); }
        } catch (e) { console.warn('fetch /count failed', e); }

        try {
          const rf = await fetch('/robotscount');
          if (rf.ok) {
            try {
              const data = await rf.json();
              const el = document.querySelector('#nb_processing');
              if (el && data.count && typeof data.count.all !== 'undefined') el.textContent = data.count.all;
            } catch (e) { console.warn('/robotscount: invalid json', e); }
          } else { console.warn('/robotscount returned', rf.status); }
        } catch (e) { console.warn('fetch /robotscount failed', e); }
      })();

      // ------- Language & engine logic -------
      const languageDb = [
        { name: 'English', value: 'en', deepl: false },
        { name: 'Arabic', value: 'ar', deepl: true },
        { name: 'Bulgarian', value: 'bg', deepl: true },
        { name: 'Chinese (Simplified)', value: 'zh-CN', deepl: true },
        { name: 'Chinese (Traditional)', value: 'zh-TW', deepl: true },
        { name: 'Czech', value: 'cs', deepl: true },
        { name: 'French', value: 'fr', deepl: true },
        { name: 'German', value: 'de', deepl: true },
        { name: 'Hindi', value: 'hi', deepl: true },
        { name: 'Hungarian', value: 'hu', deepl: true },
        { name: 'Indonesian', value: 'id', deepl: true },
        { name: 'Italian', value: 'it', deepl: true },
        { name: 'Japanese', value: 'ja', deepl: true },
        { name: 'Korean', value: 'ko', deepl: true },
        { name: 'Malay', value: 'ms', deepl: true },
        { name: 'Mongolian', value: 'mn', deepl: true },
        { name: 'Nepali', value: 'ne', deepl: true },
        { name: 'Persian', value: 'fa', deepl: true },
        { name: 'Polish', value: 'pl', deepl: true },
        { name: 'Punjabi', value: 'pa', deepl: true },
        { name: 'Romanian', value: 'ro', deepl: true },
        { name: 'Russian', value: 'ru', deepl: true },
        { name: 'Spanish', value: 'es', deepl: true },
        { name: 'Telugu', value: 'te', deepl: true },
        { name: 'Thai', value: 'th', deepl: false },
        { name: 'Ukrainian', value: 'uk', deepl: true },
        { name: 'Urdu', value: 'ur', deepl: true },
        { name: 'Vietnamese', value: 'vi', deepl: true }
      ];

      const sourceSelector = document.querySelector('#sourceLanguages');
      const targetSelector = document.querySelector('#targetLanguages');

      // populate source selector
      languageDb.forEach(lang => {
        const opt = document.createElement('option');
        opt.textContent = lang.name;
        opt.value = lang.value;
        sourceSelector.appendChild(opt);
      });

      // setDefault=true → called from a language change: apply Persian default engine.
      // setDefault=false (or omitted) → called from engine change / page restore:
      //   update UI state only, never override the user's engine choice.
      function engineChecker(setDefault) {
        const targetLanguage = targetSelector.value;
        const deeplAttr = targetSelector.selectedOptions && targetSelector.selectedOptions[0]
          ? targetSelector.selectedOptions[0].getAttribute('deepl') : 'false';
        const deepl = deeplAttr === 'true' || deeplAttr === 'True';

        const deeplOption        = document.querySelector('#deepl-engine-option');
        const googleOption       = document.querySelector('#google-engine-option');
        const openaiAPIOption    = document.querySelector('#openai-engine-option');
        const openaiPolishOption = document.querySelector('#openai-polish-engine-option');

        // OpenAI API always available
        if (openaiAPIOption) openaiAPIOption.disabled = false;

        // OpenAI + Polish: only for Persian — disable when not Persian
        const engineSel = document.getElementById('translationEngine');
        if (openaiPolishOption) {
          if (targetLanguage !== 'fa') {
            openaiPolishOption.disabled = true;
            // If chatgpt-polish was active, switch to Google as fallback
            // (only when this is triggered by a language change, not engine change)
            if (setDefault && engineSel && engineSel.value === 'chatgpt-polish') {
              if (googleOption) googleOption.selected = true;
            }
          } else {
            openaiPolishOption.disabled = false;
          }
        }

        // DeepL availability — only update disabled state here.
        // Selecting a default engine is handled below, guarded by setDefault.
        const deeplLangs = [
          'ar', 'bg', 'zh-CN', 'zh-TW', 'cs', 'fr', 'de', 'hu', 'id',
          'it', 'ja', 'ko', 'pl', 'ro', 'ru', 'es', 'uk', 'vi', 'pa', 'fa', 'hi'
        ];
        if (deeplOption) {
          const deeplAvail = deepl && deeplLangs.includes(targetLanguage);
          deeplOption.disabled = !deeplAvail;
          // If DeepL is now disabled but was selected, fall back — only on lang change
          if (!deeplAvail && setDefault && engineSel && engineSel.value === 'deepl') {
            if (googleOption) googleOption.selected = true;
          }
        }

        // Split engine: enabled for Persian only. Persian Double Lines is
        // the default Split Method for FA; the option is hidden for every
        // other target language and reverts to "basic" if it was active.
        const splitEnabledLanguages = ['fa'];
        const splitSel = document.getElementById("splitEngine");
        const pdlOption = document.getElementById("persian-double-lines-split-option");
        if (splitEnabledLanguages.includes(targetLanguage)) {
          splitSel.disabled = false;
          if (pdlOption) {
            pdlOption.hidden = false;
            pdlOption.selected = true;
          }
        } else {
          if (pdlOption) {
            pdlOption.hidden = true;
            if (splitSel.value === 'persian_double_lines') splitSel.value = 'basic';
          }
          document.querySelector("#basic-split-option").selected = true;
          splitSel.disabled = true;
        }

        // Phase 1 detached the FA aligner from the chatgpt-polish engine,
        // so the splitSection is no longer hidden when fa+chatgpt-polish
        // is selected — the user picks "Persian Double Lines" from the
        // Split Method dropdown to get the doubling behaviour. Keep the
        // splitSection visible for every combination.
        const splitSection = document.getElementById('splitSection');
        if (splitSection) {
          splitSection.style.display = '';
        }

        // Aligner MAX_CHARS slider: only meaningful when persian_double_lines
        // is the active Split Method. Hidden otherwise.
        const maxCharsRow = document.getElementById('alignerMaxCharsRow');
        if (maxCharsRow) {
          const isPDL = splitSel && splitSel.value === 'persian_double_lines';
          maxCharsRow.classList.toggle('hidden', !isPDL);
        }

        // Aligner LLM threshold row: only meaningful when the active split
        // method is persian_double_lines. Hidden otherwise.
        const alignerRow = document.getElementById('alignerThresholdRow');
        if (alignerRow) {
          const isPDL = splitSel && splitSel.value === 'persian_double_lines';
          alignerRow.classList.toggle('hidden', !isPDL);
        }

        // Apply language-specific default engine — only on language change (setDefault=true).
        // Never runs when called from an engine-change or page-restore event,
        // so the user's explicit choice is never overridden.
        if (setDefault && engineSel) {
          if (targetLanguage === 'fa' && openaiPolishOption && !openaiPolishOption.disabled) {
            // Persian → chatgpt-polish
            engineSel.value = 'chatgpt-polish';
          } else if (deeplOption && !deeplOption.disabled) {
            // Language supports DeepL → DeepL
            engineSel.value = 'deepl';
          } else {
            // Fallback → Google
            engineSel.value = 'google';
          }
        }

        // Show AI model selector only when OpenAI engine is selected
        const aiModelRow = document.getElementById('aiModelRow');
        if (aiModelRow && engineSel) {
          const eng = engineSel.value;
          aiModelRow.style.display = (eng === 'chatgpt' || eng === 'chatgpt-polish') ? '' : 'none';
        }
      }

		

      function setTargetLangs() {
        const filterLangs = languageDb.filter(l => l.value !== sourceSelector.value);
        targetSelector.innerHTML = '';
        filterLangs.forEach(lang => {
          const opt = document.createElement('option');
          opt.textContent = lang.name;
          opt.value = lang.value;
          opt.setAttribute('deepl', lang.deepl);
          targetSelector.appendChild(opt);
        });
        engineChecker(true);  // language rebuilt → apply language-specific defaults
      }

      sourceSelector.addEventListener('change', setTargetLangs);
      // Language changed by user → apply language-specific engine default
      targetSelector.addEventListener('change', () => engineChecker(true));
      setTargetLangs();

      // ------- Remember language selection (localStorage) -------
      // Policy: ONLY language is persisted. Engine is intentionally NOT saved
      // so that every page load starts with the correct language-specific
      // default engine (chatgpt-polish for Persian, DeepL/Google for others).
      // This prevents a one-time test with a lower-quality engine from becoming
      // a permanent setting the user forgets about.

      const engineSelector  = document.getElementById('translationEngine');
      const aiModelSelector = document.getElementById('aiModel');

      // Safe localStorage helpers — silently no-ops when storage is restricted
      // (private/incognito mode, storage quota exceeded, browser policy, etc.)
      const _lsSet = (key, val) => { try { localStorage.setItem(key, val); } catch (_) {} };
      const _lsGet = (key)      => { try { return localStorage.getItem(key); } catch (_) { return null; } };
      const _lsDel = (key)      => { try { localStorage.removeItem(key); }    catch (_) {} };

      const saveLanguagePrefs = () => {
        // Save language only — never engine or model
        _lsSet('savedSourceLang', sourceSelector.value);
        _lsSet('savedTargetLang',  targetSelector.value);
        // Remove any stale engine/model keys left from previous versions
        _lsDel('savedEngine');
        _lsDel('savedAiModel');
      };

      const loadLanguagePrefs = () => {
        // Clean up stale keys from older code that saved engine/model
        _lsDel('savedEngine');
        _lsDel('savedAiModel');

        const savedSource = _lsGet('savedSourceLang');
        const savedTarget = _lsGet('savedTargetLang');

        // 1. Restore source language and rebuild target list
        if (savedSource) {
          const srcOpt = sourceSelector.querySelector(`option[value="${savedSource}"]`);
          if (srcOpt) {
            sourceSelector.value = savedSource;
            setTargetLangs();   // rebuilds target list, calls engineChecker(true)
          }
        }

        // 2. Restore target language (only if the option still exists in the list)
        if (savedTarget) {
          const tgtOpt = targetSelector.querySelector(`option[value="${savedTarget}"]`);
          if (tgtOpt) {
            targetSelector.value = savedTarget;
            // Apply language-specific default engine for the restored language
            engineChecker(true);
          }
        }
        // engineChecker(true) already called above; nothing more to do.
        // Engine is always the language default on every page load.
      };

      // Save language whenever source or target changes
      sourceSelector.addEventListener('change', saveLanguagePrefs);
      targetSelector.addEventListener('change', saveLanguagePrefs);
      // Engine/model changes are NOT saved (intentional — see policy above)

      // Show/hide AI model row + Split section when engine changes.
      // setDefault=false: user explicitly chose an engine — never override.
      engineSelector.addEventListener('change', () => {
        engineChecker(false);
        const aiModelRow = document.getElementById('aiModelRow');
        if (aiModelRow) {
          const eng = engineSelector.value;
          aiModelRow.style.display = (eng === 'chatgpt' || eng === 'chatgpt-polish') ? '' : 'none';
        }
      });

      // Restore on page load
      loadLanguagePrefs();

      // ------- File validation -------
      window.validateFile = function validateFile() {
        const fileInput = document.getElementById('docxFile');
        if (!fileInput || fileInput.files.length === 0) return;
        const file = fileInput.files[0];
        const fileName = file.name.toUpperCase().replace(/）/g, ')').replace(/（/g, '(');

        if (!fileName.endsWith('.DOCX')) {
          if (fileName.endsWith('.DOC')) {
            // fallback to simple confirm: using native confirm here is OK because it's synchronous and user-initiated
            const go = confirm('The file format is .doc. Do you want to convert it to .docx first?');
            if (go) safeOpenURL('https://convertio.co/doc-docx/');
            else showAlert('Error: file format is not .docx. Please convert to docx format using your word processor (Libre Office, Microsoft Office, etc.) or another online tool.');
          } else {
            showAlert('Invalid file format. Please select a .docx file.');
          }
          fileInput.value = '';
          return;
        }

        const reader = new FileReader();
        reader.onload = function (e) {
          try {
            const uint8 = new Uint8Array(e.target.result);
            if (uint8[0] === 0x50 && uint8[1] === 0x4B) {
              // Valid .docx (zip) - nothing to do
              console.log('Valid .docx ZIP file');
            } else {
              showAlert('Invalid file content. The selected file is not a valid Microsoft Word .docx file. Please convert and try again.');
              fileInput.value = '';
            }
          } catch (err) {
            showAlert('An error occurred while reading the file.');
            fileInput.value = '';
          }
        };
        reader.onerror = function () { showAlert('An error occurred while reading the file.'); fileInput.value = ''; };
        reader.readAsArrayBuffer(file);
      };

      // ------- Polling helper -------
      // Update the progress bar from a /status response. Map known
      // PROGRESS checkpoints to short human labels so the user has
      // context for the percentage they see.
      function _progressLabel(pct) {
        if (pct >= 100) return 'Finalizing…';
        if (pct >= 90)  return 'Aligning…';
        if (pct >= 75)  return 'Almost done…';
        if (pct >= 65)  return 'Polishing…';
        if (pct >= 15)  return 'Translating…';
        if (pct >= 10)  return 'Backend started…';
        if (pct >= 5)   return 'Job queued…';
        return 'Starting…';
      }
      function _updateProgress(pct) {
        if (typeof pct !== 'number' || pct < 0) return;
        const bar   = document.getElementById('progressBar');
        const lbl   = document.getElementById('progressLabel');
        const pctEl = document.getElementById('progressPct');
        if (bar)   bar.value      = pct;
        if (pctEl) pctEl.textContent = pct + '%';
        if (lbl)   lbl.textContent   = _progressLabel(pct);
      }

      async function pollJobStatus(jobId) {
        const POLL_INTERVAL = 4000;         // check every 4 seconds
        const MAX_WAIT      = 40 * 60 * 1000; // 40 minutes max
        const start = Date.now();

        while (Date.now() - start < MAX_WAIT) {
          await new Promise(r => setTimeout(r, POLL_INTERVAL));
          try {
            const res = await fetch('/status/' + jobId);
            if (!res.ok) continue; // network glitch — retry silently
            const data = await res.json();
            if (typeof data.progress === 'number') _updateProgress(data.progress);
            if (data.status === 'done')  { _updateProgress(100); return { filename: data.filename }; }
            if (data.status === 'error') throw new Error(data.error || 'Translation failed on server.');
            if (data.status === 'cancelled') throw new Error('Translation cancelled by user.');
            // 'pending' → keep polling
          } catch (err) {
            // Re-throw terminal errors; swallow transient network errors
            if (err.message && (
              err.message.includes('Translation failed') ||
              err.message.includes('Translation cancelled') ||
              err.message.includes('timed out') ||
              err.message.includes('not found')
            )) throw err;
            console.warn('Poll retry (network?):', err.message);
          }
        }
        throw new Error('Translation timed out after 40 minutes. Please try again.');
      }

      // ------- Persist file selection across DOM churn -------
      // The legacy form occasionally clears the <input type="file">'s
      // FileList when other selects are toggled (some browsers do this
      // when the surrounding form re-layouts). Cache the chosen File
      // object the moment the user picks it, and fall back to the
      // cached copy in sendToServer when the input has gone empty.
      let _persistedDocxFile = null;
      const _docxInputEl = document.getElementById('docxFile');
      if (_docxInputEl) {
        _docxInputEl.addEventListener('change', () => {
          if (_docxInputEl.files && _docxInputEl.files.length > 0) {
            _persistedDocxFile = _docxInputEl.files[0];
          }
        });
      }

      // ------- Upload & poll download -------
      async function sendToServer() {
        const docxFileInput = document.getElementById('docxFile');
        const docxFile = (docxFileInput && docxFileInput.files.length > 0)
          ? docxFileInput.files[0]
          : _persistedDocxFile;
        if (!docxFile) {
          await showAlert('Please select a Word .docx file to translate.');
          return;
        }

        loadingElement.classList.add('visible');
        _updateProgress(0);

        const formData = new FormData();
        const sanitizedFileName = docxFile.name.replace(/）/g, ')').replace(/（/g, '(').replace(/&/g, '');
        formData.append('file', docxFile, sanitizedFileName);

        const sourceLanguage    = document.getElementById('sourceLanguages').value;
        let   targetLanguage    = document.getElementById('targetLanguages').value;
        const translationEngine = document.getElementById('translationEngine').value;
        const splitTranslate    = document.getElementById('splitTranslate').checked;
        let   splitEngine       = document.getElementById('splitEngine').value;
        const aiModelEl         = document.getElementById('aiModel');
        const aiModel           = aiModelEl ? aiModelEl.value : '';

        if (targetLanguage === 'zh-CN' && translationEngine === 'deepl') targetLanguage = 'zh-hans';
        else if (targetLanguage === 'zh-TW' && translationEngine === 'deepl') targetLanguage = 'zh-hant';

        formData.append('sourceLanguage',    sourceLanguage);
        formData.append('targetLanguage',    targetLanguage);
        formData.append('translationEngine', translationEngine);
        formData.append('splitTranslate',    splitTranslate);
        if (splitTranslate) formData.append('splitEngine', splitEngine);
        if (splitTranslate && splitEngine === 'persian_double_lines') {
          const thrEl = document.getElementById('alignerLlmThreshold');
          const thr   = thrEl ? Number(thrEl.value) : 0;
          formData.append('alignerLlmThreshold', String(thr));

          // 2026-05-15: per-job MAX_CHARS for the FA aligner.
          // Clamped to 24..70; default 45. Stored in localStorage so
          // the user's preference persists across sessions.
          const mcEl = document.getElementById('alignerMaxChars');
          let   mc   = mcEl ? Number(mcEl.value) : 45;
          if (!Number.isFinite(mc)) mc = 45;
          mc = Math.max(24, Math.min(70, Math.round(mc)));
          formData.append('alignerMaxChars', String(mc));
        }
        if (aiModel)        formData.append('aiModel', aiModel);

        try {
          // Step 1: Upload file and receive a jobId immediately
          const uploadRes = await fetch('/upload', { method: 'POST', body: formData });
          if (!uploadRes.ok) throw new Error('Upload failed: ' + uploadRes.status);

          let uploadData;
          try { uploadData = await uploadRes.json(); }
          catch (e) { throw new Error('Invalid JSON from server on upload'); }

          if (!uploadData.ok) {
            await showAlert(uploadData.comment || JSON.stringify(uploadData, null, 2));
            return;
          }

          // Phase 12 — cache feedback. The launcher returns
          //   cacheHit:      true  when the engine call was skipped
          //   splitterOnly:  true  when the cached translation was reused
          //                        but a different Split Method was applied
          //                        on top — e.g. a follow-up upload of the
          //                        same source switching from `basic` to
          //                        `persian_double_lines`.
          const cacheHit      = !!uploadData.cacheHit;
          const splitterOnly  = !!uploadData.splitterOnly;

          // Wire the Cancel button to POST /cancel/<jobId> for *this* job.
          // Removed when the job ends (any status).
          const _cancelBtn = document.getElementById('cancelBtn');
          let _cancelHandler = null;
          if (_cancelBtn) {
            _cancelHandler = async () => {
              _cancelBtn.disabled = true;
              try {
                await fetch('/cancel/' + encodeURIComponent(uploadData.jobId),
                            { method: 'POST' });
              } catch (_) { /* the polling loop will see status=cancelled */ }
            };
            _cancelBtn.addEventListener('click', _cancelHandler);
          }

          // Step 2: Poll until translation finishes
          const { filename } = await pollJobStatus(uploadData.jobId);

          if (_cancelBtn && _cancelHandler) {
            _cancelBtn.removeEventListener('click', _cancelHandler);
            _cancelBtn.disabled = false;
          }

          // Step 3: Trigger the single-file download. Phase 7 of the
          // persian-double-lines roadmap collapsed the multi-file output
          // (TranslatePolish + Classic + Double) to one docx per job, so
          // the Chrome multi-download permission prompt no longer applies
          // and the timed-sequential / ZIP-bundle workarounds are gone.
          function triggerDownload(href) {
            const a = document.createElement('a');
            a.href = href;
            a.download = '';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
          }

          let displayName = filename
            .replace(/^\d{13}-/, '')
            .replace(/ - \d{4}-\d{2}-\d{2}T\d{6}\.\d{3}(?=\.docx$)/, '');

          // 2026-05-13: render a run-summary card from the JSON sidecar.
          // Best-effort — if the endpoint is missing or returns no log,
          // skip silently.
          try {
            const logResp = await fetch('/log/' + encodeURIComponent(filename));
            if (logResp.ok) {
              const logBody = await logResp.json();
              if (logBody && logBody.ok && logBody.log) {
                renderRunSummary(logBody.log, displayName);
              }
            }
          } catch (e) { /* sidecar fetch failed; ignore */ }

          triggerDownload('/download/' + filename.replace(/#/g, '%23'));

          // 2026-05-13: also deliver the JSON sidecar (run log) so the
          // user has a permanent record of model / tokens / cost / polish
          // stats next to the docx. Same /download/<name> endpoint; the
          // launcher detects the .json extension and serves the right
          // MIME type. HEAD-check first because not every engine path
          // produces a sidecar (e.g. when MTD_DISABLE_SIDECAR=1).
          try {
            const logName = filename.replace(/\.docx$/i, '_log.json');
            const logURL  = '/download/' + logName.replace(/#/g, '%23');
            const probe = await fetch(logURL, { method: 'GET' });
            if (probe.ok) {
              // Give the docx download a tiny head-start so the browser
              // doesn't merge them and offer a single bundled prompt.
              setTimeout(() => triggerDownload(logURL), 400);
            }
          } catch (e) { /* sidecar download failed; ignore */ }

          // Play notification sound after short delay (Safari-safe)
          setTimeout(() => {
            try {
              const enableSound  = document.getElementById('enableSound');
              const soundSelectEl = document.getElementById('soundSelect');
              if (enableSound && enableSound.checked && soundSelectEl) {
                const audio = new Audio(soundSelectEl.value);
                audio.volume = 0.5;
                audio.play().catch(err => console.warn('Autoplay prevented:', err));
              }
            } catch (e) { console.warn('Sound play failed:', e); }
          }, 500);

          flashTabTitle('Download ready!');
          let _cacheNote = '';
          if (splitterOnly) {
            _cacheNote = '\n\nTranslated text reused from cache; only the split was redone.';
          } else if (cacheHit) {
            _cacheNote = '\n\nReused from the 36-hour translation cache.';
          }
          await showAlert(`File download completed. File "${displayName}" can be found in your default download folder.${_cacheNote}`);

        } catch (err) {
          // Hide the loading overlay BEFORE the alert so the progress bar
          // doesn't keep "running" behind the dialog while the user reads
          // the error message.
          loadingElement.classList.remove('visible');
          console.error('Translation error:', err);
          await showAlert('Error: ' + (err.message || 'Please contact admin: smtv.bot (at) gmail (dot) com'));
        } finally {
          // Defensive: make sure the overlay is hidden even on the success path.
          loadingElement.classList.remove('visible');
        }
      }

      // Attach to button (safe user-initiated event)
      translateBtn.addEventListener('click', sendToServer);

      // ------- Expose sendToServer to window if needed elsewhere -------
      window.sendToServer = sendToServer;

      // ------- Aligner LLM threshold slider wiring -------
      const _alignerSlider = document.getElementById('alignerLlmThreshold');
      const _alignerValueEl = document.getElementById('alignerLlmThresholdValue');
      const _alignerRow = document.getElementById('alignerThresholdRow');
      const _splitSel   = document.getElementById('splitEngine');
      if (_alignerSlider && _alignerValueEl) {
        _alignerSlider.addEventListener('input', function () {
          _alignerValueEl.textContent = String(_alignerSlider.value);
        });
      }
      if (_splitSel && _alignerRow) {
        _splitSel.addEventListener('change', function () {
          const isPDL = _splitSel.value === 'persian_double_lines';
          _alignerRow.classList.toggle('hidden', !isPDL);
        });
      }

      // ------- Aligner MAX_CHARS slider wiring (Persian Double Lines) -------
      // Persisted across sessions in localStorage('mtd.alignerMaxChars').
      // Range 24..70, default 45. The slider hides when splitEngine != PDL.
      const _maxCharsSlider = document.getElementById('alignerMaxChars');
      const _maxCharsValueEl = document.getElementById('alignerMaxCharsValue');
      const _maxCharsRow = document.getElementById('alignerMaxCharsRow');
      const _MAX_CHARS_LS_KEY = 'mtd.alignerMaxChars';
      if (_maxCharsSlider && _maxCharsValueEl) {
        // Hydrate from localStorage on first paint.
        try {
          const stored = window.localStorage.getItem(_MAX_CHARS_LS_KEY);
          if (stored !== null) {
            const v = parseInt(stored, 10);
            if (Number.isFinite(v) && v >= 24 && v <= 70) {
              _maxCharsSlider.value = String(v);
              _maxCharsValueEl.textContent = String(v);
            }
          }
        } catch (_e) { /* private mode, ignore */ }

        _maxCharsSlider.addEventListener('input', function () {
          _maxCharsValueEl.textContent = String(_maxCharsSlider.value);
        });
        _maxCharsSlider.addEventListener('change', function () {
          // Persist after the user releases the slider, not on every drag tick.
          try {
            window.localStorage.setItem(_MAX_CHARS_LS_KEY, String(_maxCharsSlider.value));
          } catch (_e) { /* private mode, ignore */ }
        });
      }
      if (_splitSel && _maxCharsRow) {
        _splitSel.addEventListener('change', function () {
          const isPDL = _splitSel.value === 'persian_double_lines';
          _maxCharsRow.classList.toggle('hidden', !isPDL);
        });
        // Initial paint — match the current splitEngine value.
        const isPDL = _splitSel.value === 'persian_double_lines';
        _maxCharsRow.classList.toggle('hidden', !isPDL);
      }

    }); // end DOMContentLoaded
    </script>

  </body>
</html>
